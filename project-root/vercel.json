{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook.js" },
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/api/leads", "dest": "/api/leads.js" },
    { "src": "/api/scan-result", "dest": "/api/scan-result.js" },
    { "src": "/api/public-report", "dest": "/api/public-report.js" },
    { "src": "/api/download-remediated", "dest": "/api/download-remediated.js" },
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.html" },
    { "src": "/privacy-request", "dest": "/privacy-request.html" },
    { "src": "/do-not-sell", "dest": "/do-not-sell.html" },
    { "src": "/cookie-policy", "dest": "/cookie-policy.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
